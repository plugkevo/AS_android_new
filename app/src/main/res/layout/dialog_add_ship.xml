<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/et_ship_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ship Name"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/et_ship_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ship Number/Registration"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/et_imo_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="IMO Number (e.g., 9632678)"
        android:inputType="number"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="The IMO number is used to fetch live location from AIS Hub"
        android:textSize="12sp"
        android:textColor="?attr/searchHintColor" />

</LinearLayout>
